# Copy this file to `.env` and fill in real values.

# --- Database ---
# Pick ONE and paste its connection string here.
#
# Neon (cloud, recommended to start): from the Neon dashboard, "Connection string".
#   DATABASE_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/yarderp?sslmode=require"
#
# Local PostgreSQL:
#   DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/yarderp?schema=public"
#
# Docker (docker compose up):
#   DATABASE_URL="postgresql://postgres:postgres@localhost:5432/yarderp?schema=public"
DATABASE_URL=""

# --- Auth ---
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-me-too"
JWT_REFRESH_EXPIRES_IN="30d"

# --- Server ---
PORT=3000
NODE_ENV=development

# --- First super admin (used by seed script) ---
SEED_ADMIN_NAME="Owner"
SEED_ADMIN_PHONE="9999999999"
SEED_ADMIN_PASSWORD="changeme123"
